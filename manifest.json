{
  "manifest_version": 3,
  "name": "Laneway Bee",
  "version": "1.0.1",
  "description": "Auto-record Google Meet audio & video, upload to cloud storage, transcribe sessions, analyze content, and track participant engagement.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://laneway-r2-upload.laneway-r2-upload.workers.dev/*",
    "https://laneway-meeting-management.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "css": [
        "styles/content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/honeycomb.png",
      "48": "icons/honeycomb.png",
      "128": "icons/honeycomb.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/honeycomb.png",
    "48": "icons/honeycomb.png",
    "128": "icons/honeycomb.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "styles/*",
        "fonts/*"
      ],
      "matches": [
        "https://meet.google.com/*"
      ]
    }
  ]
}
